# Copie para .env no servidor e ajuste.
# URL pública do site (sem barra final)
APP_NAME=GestorGastos
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gestorgastos.rf.gd

LOG_CHANNEL=stack
LOG_LEVEL=error

# SQLite (caminho absoluto no servidor) ou MySQL do hosting
DB_CONNECTION=sqlite
# DB_DATABASE=/caminho/absoluto/database/database.sqlite

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=...
# DB_USERNAME=...
# DB_PASSWORD=...

SESSION_DRIVER=database
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# Opcional: origem do SPA se estiver noutro domínio (CORS)
# FRONTEND_URL=https://gestorgastos.rf.gd
