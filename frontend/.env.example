# Copie para .env.local para ajustes só na tua máquina (não commitar segredos).
#
# --- Desenvolvimento (npm run dev) ---
# Com proxy do Vite (recomendado): deixe como abaixo ou omita e use o default em .env.development
# VITE_API_BASE=/api/v1
#
# API noutro host na rede local:
# VITE_API_BASE=http://192.168.1.10:8000/api/v1
#
# --- Produção (npm run build) ---
# Definido em .env.production — URL pública da API (Laravel em /api/v1)
# VITE_API_BASE=https://gestorgastos.rf.gd/api/v1

VITE_API_BASE=/api/v1
