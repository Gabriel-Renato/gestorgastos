# Modo: npm run dev
# O proxy em vite.config.js encaminha /api → Laravel (ex.: http://127.0.0.1:8000)
# Usar caminho relativo para o browser pedir ao próprio Vite e o proxy tratar.
VITE_API_BASE=/api/v1

# Destino do proxy (opcional; padrão: http://127.0.0.1:8000)
# VITE_DEV_API_ORIGIN=http://127.0.0.1:8000
